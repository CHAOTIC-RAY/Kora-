{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "build:prod": "VITE_APP_CHANNEL=production vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:beta": "VITE_APP_CHANNEL=beta vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run build:prod && wrangler deploy --env production",
    "deploy:beta": "npm run build:beta && wrangler deploy --env beta",
    "cf-dev": "wrangler dev",
    "cf-dev:beta": "wrangler dev --env beta",
    "build:apk-web": "VITE_APP_CHANNEL=production vite build",
    "icons:android": "npm install --no-save sharp && node scripts/generate-android-icons.mjs",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:debug": "npm run icons:android && npm run build:apk-web && npx cap sync android && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run icons:android && npm run build:apk-web && npx cap sync android && cd android && ./gradlew assembleRelease",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "parse-dict": "tsx parse-stardict.ts"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/device": "^8.0.3",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@google/genai": "^2.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cheerio": "^1.2.0",
    "crawlee": "^3.17.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.3.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
