{
  "type": "AdaptiveCard",
  "version": "1.5",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "TextBlock",
      "text": "Kora",
      "size": "Small",
      "color": "Accent",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Continue reading",
      "size": "Medium",
      "weight": "Bolder",
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${title}",
      "wrap": true,
      "weight": "Bolder",
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "${subtitle}",
      "wrap": true,
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${progress}",
      "size": "Small",
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open in Kora",
      "url": "${openUrl}"
    }
  ]
}
