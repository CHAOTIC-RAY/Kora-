{
  "entities": {
    "BookMetadata": {
      "title": "BookMetadata",
      "description": "Library book metadata, progress, and customization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "extension": { "type": "string" },
        "size": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "title", "author", "extension", "size", "status"]
    }
  },
  "firestore": {
    "/users/{userId}/library/{bookId}": {
      "schema": "BookMetadata",
      "description": "User's synchronized book list"
    }
  }
}
