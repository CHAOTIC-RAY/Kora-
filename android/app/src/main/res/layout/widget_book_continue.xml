<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_book_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:contentDescription="@string/widget_book_description">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="72dp"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/widget_book_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_cover_frame"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_book_cover_fallback"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_cover_frame"
            android:gravity="center"
            android:text="B"
            android:textColor="#C4A574"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_book_eyebrow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="CONTINUE BOOK"
            android:textAllCaps="true"
            android:textColor="#C4A574"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_book_title"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Your book"
            android:textColor="#F7F3E3"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#A8A29E"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/widget_book_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C4A574"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
