# Using Android gitignore template: https://github.com/github/gitignore/blob/HEAD/Android.gitignore

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml

# Keystore files — never commit production keys
*.jks
*.keystore
kora-release.keystore
# Allow the dedicated CI sideload keystore (fingerprints published on Releases)
!app/keystore/kora-ci.jks
!app/keystore/FINGERPRINTS.md

# External native build folder
.externalNativeBuild
.cxx/

# Cordova plugins for Capacitor (regenerated by cap sync)
capacitor-cordova-android-plugins

# Copied web assets (regenerated by cap sync)
app/src/main/assets/public

# Generated Config files
app/src/main/assets/capacitor.config.json
app/src/main/assets/capacitor.plugins.json
app/src/main/res/xml/config.xml

# OS
.DS_Store
Thumbs.db
*.hprof
